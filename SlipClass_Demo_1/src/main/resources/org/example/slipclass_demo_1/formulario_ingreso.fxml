<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<?import javafx.scene.control.DatePicker?>
<AnchorPane prefHeight="800.0" prefWidth="800.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.slipclass_demo_1.HelloController">
    <children>
        <VBox alignment="CENTER" prefHeight="800.0" prefWidth="800.0" spacing="20.0" style="-fx-background-color: #7FFFD4;" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
            <children>
                <Label text="Crea tu cuenta" textFill="#34495e">
                    <font>
                        <Font name="System Bold" size="32.0" />
                    </font>
                </Label>

                <TextField fx:id="txtUsuario" maxWidth="300.0" promptText="Nombre de usuario" />
                <TextField fx:id="txtEmail" maxWidth="300.0" promptText="Correo electrónico" />

                <TextField fx:id="txtTelefono" maxWidth="300.0" promptText="Número de teléfono" />

                <DatePicker fx:id="dpFechaNacimiento" maxWidth="300.0" promptText="Fecha de nacimiento" />

                <PasswordField fx:id="txtPass" maxWidth="300.0" promptText="Contraseña" />
                <PasswordField fx:id="txtPassConfirm" maxWidth="300.0" promptText="Confirmar contraseña" />

                <Button prefWidth="200.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-text-fill: #34495e; -fx-font-weight: bold;" text="Finalizar Registro" />
                <Button fx:id="btnVolver" onAction="#onVolverClick" style="-fx-background-color: transparent; -fx-text-fill: #34495e; -fx-border-color: #34495e; -fx-border-radius: 20;" text="Volver al inicio" />
            </children>
        </VBox>
    </children>
</AnchorPane>